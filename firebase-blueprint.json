{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a user in the system.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "phone": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Order": {
      "title": "Order",
      "description": "Represents a purchase order.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "status": { "type": "string" },
        "shippingAddress": { "type": "object" },
        "paymentMethod": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "items", "total", "status"]
    },
    "Address": {
      "title": "Address",
      "description": "Represents a saved delivery address.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "fullName": { "type": "string" },
        "address": { "type": "string" },
        "city": { "type": "string" },
        "state": { "type": "string" },
        "zipCode": { "type": "string" },
        "phone": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "fullName", "address", "city", "state", "zipCode", "phone"]
    },
    "Payment": {
      "title": "Payment",
      "description": "Represents a saved payment method.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "cardName": { "type": "string" },
        "last4": { "type": "string" },
        "expiry": { "type": "string" },
        "type": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "cardName", "last4", "expiry"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile data"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Order records"
    },
    "/users/{userId}/addresses/{addressId}": {
      "schema": "Address",
      "description": "User's saved delivery addresses"
    },
    "/users/{userId}/payments/{paymentId}": {
      "schema": "Payment",
      "description": "User's saved payment methods"
    }
  }
}
